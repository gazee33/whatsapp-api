{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-pro",
  "small_model": "opencode-go/minimax-m2.5",
  "default_agent": "build",
  "instructions": [
    "AGENTS.md",
    ".opencode/skills/coding-standards/SKILL.md",
    ".opencode/skills/backend-patterns/SKILL.md",
    ".opencode/skills/frontend-patterns/SKILL.md",
    ".opencode/skills/api-design/SKILL.md",
    ".opencode/skills/security-review/SKILL.md",
    ".opencode/skills/tdd-workflow/SKILL.md",
    ".opencode/skills/e2e-testing/SKILL.md",
    ".opencode/skills/verification-loop/SKILL.md"
  ],
  "plugin": [".opencode/plugins"],
  "tools": {
    "run-tests": true,
    "check-coverage": true,
    "security-audit": true,
    "format-code": true,
    "lint-check": true,
    "git-summary": true,
    "changed-files": true
  },
  "agent": {
    "build": {
      "description": "Primary coding agent for the WhatsApp API project",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-pro",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "changed-files": true,
        "run-tests": true,
        "check-coverage": true,
        "security-audit": true,
        "format-code": true,
        "lint-check": true,
        "git-summary": true
      }
    },
    "planner": {
      "description": "Implementation planning for complex features and refactoring",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:.opencode/prompts/agents/planner.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "architect": {
      "description": "System design, scalability, and technical decisions",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:.opencode/prompts/agents/architect.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false
      }
    },
    "code-reviewer": {
      "description": "Code quality, security, and maintainability review",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:.opencode/prompts/agents/code-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": false,
        "edit": false,
        "lint-check": true,
        "format-code": true
      }
    },
    "security-reviewer": {
      "description": "Security vulnerability detection and remediation",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:.opencode/prompts/agents/security-reviewer.txt}",
      "tools": {
        "read": true,
        "bash": true,
        "write": true,
        "edit": true,
        "security-audit": true
      }
    },
    "tdd-guide": {
      "description": "Test-driven development with 80%+ coverage",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:.opencode/prompts/agents/tdd-guide.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "run-tests": true,
        "check-coverage": true
      }
    },
    "build-error-resolver": {
      "description": "TypeScript and build error resolution",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:.opencode/prompts/agents/build-error-resolver.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true,
        "lint-check": true
      }
    },
    "e2e-runner": {
      "description": "End-to-end testing with Playwright",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:.opencode/prompts/agents/e2e-runner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "database-reviewer": {
      "description": "Prisma schema and query optimization",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:.opencode/prompts/agents/database-reviewer.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "doc-updater": {
      "description": "Documentation and codemap updates",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:.opencode/prompts/agents/doc-updater.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    },
    "refactor-cleaner": {
      "description": "Dead code cleanup and consolidation",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.5",
      "prompt": "{file:.opencode/prompts/agents/refactor-cleaner.txt}",
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "bash": true
      }
    }
  },
  "command": {
    "plan": {
      "description": "Create a detailed implementation plan",
      "template": "{file:.opencode/commands/plan.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "tdd": {
      "description": "Enforce TDD workflow with 80%+ coverage",
      "template": "{file:.opencode/commands/tdd.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "code-review": {
      "description": "Review code for quality and maintainability",
      "template": "{file:.opencode/commands/code-review.md}\n\n$ARGUMENTS",
      "agent": "code-reviewer",
      "subtask": true
    },
    "security": {
      "description": "Run comprehensive security review",
      "template": "{file:.opencode/commands/security.md}\n\n$ARGUMENTS",
      "agent": "security-reviewer",
      "subtask": true
    },
    "build-fix": {
      "description": "Fix build and TypeScript errors",
      "template": "{file:.opencode/commands/build-fix.md}\n\n$ARGUMENTS",
      "agent": "build-error-resolver",
      "subtask": true
    },
    "e2e": {
      "description": "Generate and run E2E tests with Playwright",
      "template": "{file:.opencode/commands/e2e.md}\n\n$ARGUMENTS",
      "agent": "e2e-runner",
      "subtask": true
    },
    "refactor-clean": {
      "description": "Remove dead code and consolidate duplicates",
      "template": "{file:.opencode/commands/refactor-clean.md}\n\n$ARGUMENTS",
      "agent": "refactor-cleaner",
      "subtask": true
    },
    "orchestrate": {
      "description": "Orchestrate multiple agents for complex tasks",
      "template": "{file:.opencode/commands/orchestrate.md}\n\n$ARGUMENTS",
      "agent": "planner",
      "subtask": true
    },
    "update-docs": {
      "description": "Update project documentation",
      "template": "{file:.opencode/commands/update-docs.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    },
    "update-codemaps": {
      "description": "Update codemaps",
      "template": "{file:.opencode/commands/update-codemaps.md}\n\n$ARGUMENTS",
      "agent": "doc-updater",
      "subtask": true
    },
    "test-coverage": {
      "description": "Analyze test coverage",
      "template": "{file:.opencode/commands/test-coverage.md}\n\n$ARGUMENTS",
      "agent": "tdd-guide",
      "subtask": true
    },
    "verify": {
      "description": "Run verification loop before commits",
      "template": "{file:.opencode/commands/verify.md}\n\n$ARGUMENTS"
    }
  },
  "permission": {
    "mcp_*": "ask"
  },
  "mcp": {
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    }
  }
}
