# ─── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── CORS ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── IAM (Authentication) ───────────────────────────────────────────
# Required in production. Generate: openssl rand -hex 32
JWT_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ─── Default LLM provider ───────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GEMINI_API_KEY=your-gemini-api-key

# ─── Optional providers (only set if your business selects them) ────
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# OpenCode Go (cloud LLM via opencode.ai)
# Get your API key at https://opencode.ai/auth
OPENCODE_API_KEY=

# ─── Google Maps (distance-based delivery) ────────────────────────
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable: Geocoding API + Distance Matrix API
GOOGLE_MAPS_API_KEY=

# ─── DualHook Platform API (WhatsApp embedded signup) ───────────────
DUALHOOK_API_KEY=dh_live_xxx
DUALHOOK_SIGNING_SECRET=whsec_xxx
DUALHOOK_API_BASE=https://dualhook.com/api/v1
DUALHOOK_REDIRECT_BASE=http://localhost:3000
