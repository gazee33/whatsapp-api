# Database
DATABASE_URL="file:./dev.db"

# Default LLM (can be overridden per-business in DB)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
GEMINI_API_KEY=your-gemini-api-key

# Optional: Only needed if a business selects these providers
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# OpenCode Go (cloud LLM via opencode.ai)
# Get your API key at https://opencode.ai/auth
OPENCODE_API_KEY=

# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# DualHook Platform API (WhatsApp embedded signup)
DUALHOOK_API_KEY=dh_live_xxx
DUALHOOK_SIGNING_SECRET=whsec_xxx
DUALHOOK_API_BASE=https://dualhook.com/api/v1
DUALHOOK_REDIRECT_BASE=https://nadil.cloud