generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── ONBOARDING PRESET ──────────────────────────────────────────────────────

model OnboardingPreset {
  id                        String     @id @default(cuid())
  name                      String
  description               String     @default("")
  tonePreset                String     @default("casual")
  defaultCustomInstructions String     @default("")
  isActive                  Boolean    @default(true)
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  businesses                Business[]
}

// ─── TENANT (existing Business model) ───────────────────────────────────────

model Business {
  id                  String   @id @default(cuid())
  name                String
  whatsappPhoneNumberId String?  @unique
  whatsappPhoneNumber   String?
  whatsappAccessToken   String?
  whatsappAppSecret     String?
  whatsappVerifyToken   String?  @unique
  apiKey              String   @unique
  createdAt           DateTime @default(now())

  onboardingPresetId     String?
  onboardingPreset       OnboardingPreset? @relation(fields: [onboardingPresetId], references: [id])
  messagesPerMinute      Int @default(30)      // enforced in webhook route (fixed window)
  tokensPerDay           Int @default(100000)  // stored, not yet enforced — reserved for future token metering
  maxToolCallsPerSession Int @default(10)      // stored, not yet enforced — reserved for future tool-call cap

  customers    Customer[]
  categories   MenuCategory[]
  orders       Order[]
  complaints  Complaint[]
  settings    RestaurantSettings?
  users       User[]
  roles       Role[]
  auditLogs   AuditLog[]
  dualhookConnections DualhookConnection[]
  whatsappTemplates   WhatsAppTemplate[]
  managers    Manager[]

  @@map("Business")
}

// ─── MANAGER ASSISTANT ──────────────────────────────────────────────────────

model Manager {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phone      String
  name       String?
  isOwner    Boolean  @default(false)
  createdAt  DateTime @default(now())

  messages   ManagerMessage[]

  @@unique([businessId, phone])
  @@index([businessId])
  @@map("Manager")
}

model ManagerMessage {
  id        String   @id @default(cuid())
  managerId String
  manager   Manager  @relation(fields: [managerId], references: [id], onDelete: Cascade)
  role      String
  content   String
  sessionId String
  createdAt DateTime @default(now())

  @@index([managerId])
  @@index([sessionId])
  @@map("ManagerMessage")
}

// ─── IAM: USERS ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  businessId   String?
  business     Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  email        String
  passwordHash String
  name         String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  attributes   String?

  failedLoginAttempts Int  @default(0)
  lockedUntil         DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  sessions     Session[]
  roles        UserRole[]
  auditLogs    AuditLog[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
  @@map("User")
}

// ─── PLATFORM SETTINGS ──────────────────────────────────────────────────────

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("PlatformSetting")
}

// ─── PLATFORM CONFIG ───────────────────────────────────────────────────────

model PlatformConfig {
  id                    String   @id @default(cuid())

  // Prompt Configuration — monolithic (legacy, kept for backward compat)
  promptTemplate        String   @default("")
  promptVersion         String   @default("1.0")
  enableCustomPrompt    Boolean  @default(false)

  // Prompt Section Overrides — per-section editors (priority over promptTemplate when any are set)
  identityTemplate    String   @default("")
  workflowTemplate    String   @default("")
  guardrailsTemplate  String   @default("")
  toolsTemplate       String   @default("")
  interactiveTemplate String   @default("")

  // Tenant Rule Validation — applied to RestaurantSettings.customInstructions
  forbiddenPatterns    String   @default("[]")  // JSON regex[] denylist
  maxCustomRuleLength  Int      @default(500)

  // LLM Settings
  defaultLLMProvider    String   @default("gemini")
  defaultLLMModel       String   @default("llama-3.3-70b-versatile")
  maxTokens            Int       @default(4096)
  temperature          Float     @default(0.7)
  maxToolIterations    Int       @default(6)

  // LLM Failover and Global Safety
  providerFailoverOrder String @default("[]")   // JSON: ["opencode","gemini","groq"]
  globalForbiddenWords  String @default("[]")   // JSON: ["word1","word2"]

  // Manager Assistant Prompt Templates (platform-level, applies to all tenants)
  managerEnabled            Boolean @default(false)
  managerIdentityTemplate   String  @default("")
  managerWorkflowTemplate   String  @default("")
  managerGuardrailsTemplate String  @default("")
  managerToolsTemplate      String  @default("")

  // Feature Flags
  interactiveListMessagesEnabled    Boolean @default(true)
  interactiveButtonsMessagesEnabled Boolean @default(true)
  complaintToolEnabled               Boolean @default(true)
  orderStatusToolEnabled             Boolean @default(true)
  flagCustomerToolEnabled            Boolean @default(true)
  autoUpsellEnabled                  Boolean @default(false)

  // Metadata
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("PlatformConfig")
}

// ─── IAM: ROLES ─────────────────────────────────────────────────────────────

model Role {
  id          String    @id @default(cuid())
  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isSystem    Boolean   @default(false)
  conditions  String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("Role")
}

// ─── IAM: PERMISSIONS (global catalog) ──────────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  category    String
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@map("Permission")
}

// ─── IAM: USER-ROLE JUNCTION ────────────────────────────────────────────────

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("UserRole")
}

// ─── IAM: ROLE-PERMISSION JUNCTION ──────────────────────────────────────────

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("RolePermission")
}

// ─── IAM: SESSIONS ──────────────────────────────────────────────────────────

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String    @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime

  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  @@index([userId])
  @@index([refreshToken])
  @@map("Session")
}

// ─── IAM: AUDIT LOG ─────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  action      String
  resource    String?
  resourceId  String?
  details     String?
  actorRef    String?   // e.g. "manager:+966501234567" for manager-agent actions

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("AuditLog")
}

// ─── DUALHOOK CONNECTION ─────────────────────────────────────────────────────

model DualhookConnection {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  connectionId     String   @unique
  wabaId           String
  phoneNumberId    String?  @unique
  displayPhoneNumber String?
  verifiedName     String?

  status           String   @default("active")
  connectionMode   String?

  heartbeatStatus  String?
  heartbeatLastConfirmedAt DateTime?
  heartbeatNextDueAt      DateTime?

  webhookUrl       String?
  webhookVerifyToken String?

  metadata         String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([businessId])
  @@index([status])
  @@map("DualhookConnection")
}

// ─── WHATSAPP TEMPLATE ──────────────────────────────────────────────────────

model WhatsAppTemplate {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  metaTemplateId String?
  name         String
  category     String
  language     String
  status       String   @default("PENDING")
  components   String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
  @@index([status])
  @@map("WhatsAppTemplate")
}

// ─── EXISTING MODELS ────────────────────────────────────────────────────────

model Customer {
  id                 String   @id @default(cuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phone              String
  name               String?
  cartState          String?
  flaggedForSupport  Boolean  @default(false)
  createdAt          DateTime @default(now())
  messages           Message[]
  orders             Order[]
  complaints         Complaint[]

  @@unique([businessId, phone])
  @@index([businessId])
  @@map("Customer")
}

model Message {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  role       String
  content    String
  sessionId  String
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@map("Message")
}

model MenuCategory {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  nameAr     String?
  sortOrder  Int        @default(0)
  items      MenuItem[]

  @@map("MenuCategory")
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  nameAr      String?
  description   String?
  allergens     String?      // JSON array e.g. ["peanut","dairy","gluten","egg"]
  basePrice     Float?       @map("base_price")
  hasOptions    Boolean      @default(false) @map("has_options")
  image         String?
  available     Boolean      @default(true)
  categoryId    String
  category      MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  options       Option[]

  @@map("MenuItem")
}

model Option {
  id         String      @id @default(cuid())
  itemId     String
  menuItem   MenuItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name       String
  price      Float       @default(0)
  orderItems OrderItem[]

  @@map("Option")
}

model Order {
  id              String      @id @default(cuid())
  referenceId     String      @unique
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status          String      @default("pending")
  totalPrice      Float
  notes           String?
  orderType       String?
  deliveryAddress String?
  deliveryNotes   String?
  deliveryDistanceKm Float?
  customerLatitude   Float?
  customerLongitude  Float?
  contactPhone    String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("Order")
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  optionId   String?
  option     Option?  @relation(fields: [optionId], references: [id], onDelete: SetNull)
  quantity   Int
  notes      String?

  @@map("OrderItem")
}

model Complaint {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  status    String   @default("open")
  createdAt DateTime @default(now())

  @@map("Complaint")
}

model RestaurantSettings {
  id           String  @id @default(cuid())
  businessId   String  @unique
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String  @default("My Restaurant")
  openingTime  String  @default("09:00")
  closingTime  String  @default("23:00")
  welcomeMsg  String  @default("Welcome! How can I help you today?")
  aiRules     String  @default("")
  currency    String  @default("SAR")

  address      String?
  latitude     Float?
  longitude    Float?
  phoneNumber  String?

  deliveryEnabled Boolean @default(false)
  dineInEnabled    Boolean @default(true)
  pickupEnabled    Boolean @default(true)

  deliveryTiers          String?
  maxDeliveryDistanceKm  Float?

  estimatedPrepTimeMinutes Int?
  paymentMethods           String  @default("[\"cash\",\"card\"]")
  isTemporarilyClosed      Boolean @default(false)
  defaultLanguage          String  @default("en")

  // AI Behavior — Phase 3 (structured replacements for `aiRules` free-text)
  tonePreset         String  @default("casual")   // formal | casual | playful | professional
  upsellEnabled      Boolean @default(false)
  upsellMaxPerOrder  Int     @default(1)
  customInstructions String  @default("")         // free-form, capped + validated
  escalationKeywords String  @default("[]")       // JSON string[] — extra trigger phrases
  aiRulesVersion     Int     @default(1)          // bump on any AI-config save → busts prompt cache

  // Phase 5 — Operational must-haves
  weeklySchedule     String  @default("[]")        // JSON: [{day:"mon",open:true,from:"09:00",to:"22:00"},...]
  closureExceptions  String  @default("[]")        // JSON: ["2025-12-25","2026-01-01",...]
  afterHoursPolicy   String  @default("inform_only") // "collect_order"|"inform_only"|"silence"
  minOrderValue      Float   @default(0)
  maxOrderItemCount  Int?
  featuredItems      String  @default("[]")        // JSON array of MenuItem IDs (strings)
  hiddenItems        String  @default("[]")        // JSON array of MenuItem IDs (strings)

  // Phase 6 — UX polish
  logoUrl            String?
  coverUrl           String?
  mapsUrl            String?
  showAddressByName  Boolean @default(false)
  confirmationStyle  String  @default("summary")   // "summary"|"itemized"|"minimal"
  cancellationPolicy String  @default("")

  @@map("RestaurantSettings")
}

model ErrorLog {
  id         String   @id @default(cuid())
  businessId String
  customerId String?
  sessionId  String?
  errorType String
  errorMessage String
  errorStack  String?
  context    String?
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([customerId])
  @@index([createdAt])
  @@map("ErrorLog")
}