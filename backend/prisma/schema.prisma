generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── TENANT (existing Business model) ───────────────────────────────────────

model Business {
  id                  String   @id @default(cuid())
  name                String
  whatsappPhoneNumberId String?  @unique
  whatsappPhoneNumber   String?
  whatsappAccessToken   String?
  whatsappAppSecret     String?
  whatsappVerifyToken   String?  @unique
  apiKey              String   @unique
  createdAt           DateTime @default(now())
  
  customers    Customer[]
  categories   MenuCategory[]
  orders       Order[]
  complaints  Complaint[]
  settings    RestaurantSettings?
  users       User[]
  roles       Role[]
  auditLogs   AuditLog[]
  dualhookConnections DualhookConnection[]

  @@map("Business")
}

// ─── IAM: USERS ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  businessId   String?   // null = platform-level user
  business     Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  email        String
  passwordHash String
  name         String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  attributes   String?   // JSON: custom attributes for ABAC
  
  failedLoginAttempts Int  @default(0)
  lockedUntil         DateTime?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?
  
  sessions     Session[]
  roles        UserRole[]
  auditLogs    AuditLog[]

  @@unique([businessId, email])
  @@index([businessId])
  @@index([email])
  @@map("User")
}

// ─── PLATFORM SETTINGS ───────────────────────────────────────────────────────

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   // JSON-encoded value
  description String?
  updatedAt   DateTime @updatedAt

  @@map("PlatformSetting")
}

// ─── IAM: ROLES ─────────────────────────────────────────────────────────────

model Role {
  id          String    @id @default(cuid())
  businessId  String?   // NULL = global/system role; non-NULL = tenant-specific
  business    Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  isSystem    Boolean   @default(false)
  conditions  String?   // JSON: ABAC conditions for future use
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  users       UserRole[]
  permissions RolePermission[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("Role")
}

// ─── IAM: PERMISSIONS (global catalog) ──────────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  category    String
  createdAt   DateTime @default(now())
  
  roles       RolePermission[]

  @@map("Permission")
}

// ─── IAM: USER-ROLE JUNCTION ────────────────────────────────────────────────

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("UserRole")
}

// ─── IAM: ROLE-PERMISSION JUNCTION ──────────────────────────────────────────

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("RolePermission")
}

// ─── IAM: SESSIONS ──────────────────────────────────────────────────────────

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  refreshToken String    @unique
  deviceInfo   String?
  ipAddress    String?
  expiresAt    DateTime
  
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  @@index([userId])
  @@index([refreshToken])
  @@map("Session")
}

// ─── IAM: AUDIT LOG ─────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action      String
  resource    String?
  resourceId  String?
  details     String?
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("AuditLog")
}

// ─── DUALHOOK CONNECTION ─────────────────────────────────────────────────────

model DualhookConnection {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  connectionId     String   @unique
  wabaId           String
  phoneNumberId    String?  @unique
  displayPhoneNumber String?
  verifiedName     String?

  status           String   @default("active")        // active, disconnected
  connectionMode   String?                             // coexistence, cloud_api, unknown

  // Coexistence heartbeat
  heartbeatStatus  String?                             // OK, DUE_SOON, OVERDUE
  heartbeatLastConfirmedAt DateTime?
  heartbeatNextDueAt      DateTime?

  // Webhook config
  webhookUrl       String?
  webhookVerifyToken String?

  // Onboarding session metadata (round-tripped)
  metadata         String?                             // JSON

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([businessId])
  @@index([status])
  @@map("DualhookConnection")
}

// ─── EXISTING MODELS (unchanged) ────────────────────────────────────────────

model Customer {
  id                 String   @id @default(cuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  phone              String
  name               String?
  cartState          String?
  flaggedForSupport  Boolean  @default(false)
  createdAt          DateTime @default(now())
  messages           Message[]
  orders             Order[]
  complaints         Complaint[]

  @@unique([businessId, phone])
  @@index([businessId])
  @@map("Customer")
}

model Message {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  role       String
  content    String
  sessionId  String
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@map("Message")
}

model MenuCategory {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  nameAr     String?
  sortOrder  Int        @default(0)
  items      MenuItem[]

  @@map("MenuCategory")
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  nameAr      String?
  description   String?
  basePrice     Float?       @map("base_price")
  hasOptions    Boolean      @default(false) @map("has_options")
  image         String?
  available     Boolean      @default(true)
  categoryId    String
  category      MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]
  options       Option[]

  @@map("MenuItem")
}

model Option {
  id         String      @id @default(cuid())
  itemId     String
  menuItem   MenuItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name       String
  price      Float       @default(0)
  orderItems OrderItem[]

  @@map("Option")
}

model Order {
  id              String      @id @default(cuid())
  referenceId     String      @unique
  businessId      String
  business        Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status          String      @default("pending")
  totalPrice      Float
  notes           String?
  orderType       String?
  deliveryAddress String?
  deliveryNotes   String?
  deliveryDistanceKm Float?
  customerLatitude   Float?
  customerLongitude  Float?
  contactPhone    String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("Order")
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  optionId   String?
  option     Option?  @relation(fields: [optionId], references: [id], onDelete: SetNull)
  quantity   Int
  notes      String?

  @@map("OrderItem")
}

model Complaint {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  status    String   @default("open")
  createdAt DateTime @default(now())

  @@map("Complaint")
}

model RestaurantSettings {
  id           String  @id @default(cuid())
  businessId   String  @unique
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String  @default("My Restaurant")
  openingTime  String  @default("09:00")
  closingTime  String  @default("23:00")
  welcomeMsg  String  @default("Welcome! How can I help you today?")
  aiRules     String  @default("")
  currency    String  @default("SAR")

  // Location
  address      String?
  latitude     Float?
  longitude    Float?
  phoneNumber  String?

  // Order types
  deliveryEnabled Boolean @default(false)
  dineInEnabled    Boolean @default(true)
  pickupEnabled    Boolean @default(true)

  // Delivery pricing (distance-based)
  deliveryTiers          String?   // JSON: [{"maxKm":3,"fee":5},{"maxKm":7,"fee":10},{"maxKm":10,"fee":15}]
  maxDeliveryDistanceKm  Float?

  // Operations
  estimatedPrepTimeMinutes Int?
  paymentMethods           String  @default("[\"cash\",\"card\"]")
  isTemporarilyClosed      Boolean @default(false)
  defaultLanguage          String  @default("en")

  @@map("RestaurantSettings")
}

model ErrorLog {
  id         String   @id @default(cuid())
  businessId String
  customerId String?
  sessionId  String?
  errorType String
  errorMessage String
  errorStack  String?
  context    String?
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([customerId])
  @@index([createdAt])
  @@map("ErrorLog")
}
